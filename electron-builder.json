{
  "asar": true,
  "directories": {
    "output": "release/"
  },
  "files": [
    "**/*",
    "!**/*.ts",
    "!*.map",
    "!package.json",
    "!package-lock.json",
    {
      "from": "../dist",
      "filter": [
        "**/*"
      ]
    }
  ],
  "extraResources": [
    {
      "from": "src/catalog",
      "to": "catalog"
    },
    {
      "from": "src/bin",
      "to": "bin"
    }
  ],
  "win": {
    "icon": "dist/assets/icons",
    "target": [
      "msi"
    ],
    "artifactName": "${productName}-v${version}.${ext}"
  },
  "portable": {
    "splashImage": "dist/assets/icons/electron.bmp"
  },
  "mac": {
    "icon": "dist/assets/icons",
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "icon": "dist/assets/icons",
    "category": "Utility",
    "target": [
      "AppImage", "deb", "snap"
    ]
  }
}